  // training defines special parameters for certain generations.
  // currently used for some experimental agents to "warm up" at the beginning
  // parameters for the socketio server
  "database": {
    "host": "localhost",
    "port": 5432,
    "connector": "postgresql+psycopg",
    "profiles_db": "citylearn_2022"
  },
  "server": {
    "host": "localhost",
    "port": 1883
  },
  "market": {
    "id": "",
    "type": "MicroTE4",
    "use_native_pro_rata_kernel": false,
    "batch_settlement_delivery": true,
    "close_steps": 2,
    "grid": {
      "price": 0.069,
      "fee_ratio": 1.1
    }
  },

  "participants": { // each participant must be defined in the following format
    "_default": {
      // I'd recommend keeping the name the same as the name of the synthetic profile
      "type": "Residential",
      "trader": {
        "type": "basic_trader",
        "actions": {
          "ask_price": 0.069,
          "bid_price": 0.1449
        },
        "learning": true,
        "reward_function": "net_profit"
      },
      "load": {
        "scale": 1
      },
      // do not change, the load will stay fixed at scale 1
      "generation": {
        "scale": 1
      }
      // do not change, the generation will stay fixed at scale 1
