{
  "version": "5.2.0",
  "study": {
    "name": "citylearn_test", // the simulation name defines the database name as well as local storage paths.
    "description": "",  // (optional) a description the simulation
    "start_datetime": "2016-08-01 04:0:0", // defines when a simulation starts
    "timezone": "America/Vancouver",
    "days": 365,
    "episodes": 1
  },
 "records": [
//      "metadata",
      "meter",
//      "next_observations",
      "next_actions",
      "remaining_energy",
      "state_of_charge"
  ],

  // training defines special parameters for certain generations.
  // currently used for some experimental agents to "warm up" at the beginning
  // parameters for the socketio server
  "database": {
    "host": "localhost",
    "port": 5432,
    "connector": "postgresql+psycopg",
    "profiles_db": "citylearn_2022"
  },
  "server": {
    "host": "localhost",
    "port": 1883
  },
  // parameters for market
  "market": {
    "id": "MicroTE3B",
    "type": "MicroTE3B",
    "close_steps": 2,
    "grid": {
      "price": 0.069,
      "fee_ratio": 1.1
    }
  },
  "participants": { // each participant must be defined in the following format
    "_default": {
      // the participant name must exist in the profile DB defined above
      "type": "Residential",
      "trader": {
        "track_metrics": false,
        "type": "basic_trader",
        // type must exist in the _agent/trader folder
        "bid_price": 0.14,
        // (optional) default bid price.
        "ask_price": 0.07,
        // (optional) default ask price
        "reward_function": "net_profit"
      },
      "load": {
        "scale": 1
        // multiply the load data from the profile database to be used in simulation
      },
      "generation": {
        "scale": 1
        // multiply the generation data from the profile database to be used in simulation
      },
      "storage": {
        // (optional) Defines the storage system to be attached to a participant
        "type": "Bess",
        // storage type, must exist in _devices
        "capacity": 6400,
        // Usable capacity defined in Wh
        "power": 5000,
        // constant charge/discharge rate defined in W
        "efficiency": 0.9,
        // one way efficiency. round-trip efficiency is efficiency^2
        "monthly_sdr": 0
        // monthly self-discharge rate as a fraction of usable capacity
      }
    },
