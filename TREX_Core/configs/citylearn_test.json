{
  "version": "5.2.0",
  "study": {
    "name": "citylearn_test3", // the simulation name defines the database name as well as local storage paths.
    "description": "",  // (optional) a description the simulation
    "start_datetime": "2016-08-01 04:0:0", // defines when a simulation starts
    "timezone": "America/Vancouver",
    "days": 1, // defines how many days the simulation runs
    "episodes": 300
  },
